# Docker Compose: backend + postgres
# Replace all replace-with-* placeholders before production use.

# API
API_HOST=0.0.0.0
API_PORT=3001
# In production, replace * with exact frontend origins separated by commas.
CORS_ORIGINS=https://ops.example.com,https://app.example.com
JWT_SECRET=replace-with-a-strong-random-jwt-secret
OPS_JWT_SECRET=replace-with-another-strong-random-ops-jwt-secret

# Ops admin account
OPS_ADMIN_USERNAME=ops_admin
OPS_ADMIN_PASSWORD=replace-with-a-strong-admin-password
OPS_ADMIN_DISPLAY_NAME=Ops Administrator

# Postgres container init
POSTGRES_USER=postgres
POSTGRES_PASSWORD=replace-with-a-strong-postgres-password
POSTGRES_DB=ai_iot_safety_stove_control

# Backend -> Postgres connection
PGHOST=postgres
PGPORT=5432
PGUSER=postgres
PGPASSWORD=replace-with-a-strong-postgres-password
PGDATABASE=ai_iot_safety_stove_control
PGADMIN_DATABASE=postgres

# WeChat Mini Program login
WECHAT_MINI_APP_ID=
WECHAT_MINI_APP_SECRET=

# WeChat App login
WECHAT_APP_ID=
WECHAT_APP_SECRET=

# Google App login
GOOGLE_APP_WEB_CLIENT_ID=
