{
  "name": "iot-platform-backend-dev",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "tsx watch --env-file=.env.development src/index.ts",
    "dev:test": "tsx watch --env-file=.env.test src/index.ts",
    "start": "tsx --env-file=.env.development src/index.ts",
    "start:test": "tsx --env-file=.env.test src/index.ts",
    "start:prod": "tsx --env-file=.env.production src/index.ts",
    "start:docker": "tsx src/index.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@huaweicloud/huaweicloud-sdk-core": "^3.1.206",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.6",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "google-auth-library": "^10.6.2",
    "jsonwebtoken": "^9.0.3",
    "pg": "^8.20.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.14.0",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2"
  }
}
