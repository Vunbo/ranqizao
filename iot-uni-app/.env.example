# Front-end runtime config template.
# Copy the values you need into `.env` for actual local running.
# For App or WeChat Mini Program real-device debugging, do not use localhost.
# Use your computer's LAN IP or a public domain instead.
VUE_APP_API_BASE_URL=https://api.example.com/api
VUE_APP_MINI_PROGRAM_LOGIN_PATH=/auth/mini-program/login
VUE_APP_WECHAT_APP_LOGIN_PATH=/auth/wechat/app/login
VUE_APP_BIND_WECHAT_APP_PATH=/auth/bind/wechat/app
VUE_APP_GOOGLE_APP_LOGIN_PATH=/auth/google/app/login
VUE_APP_BIND_GOOGLE_APP_PATH=/auth/bind/google/app

# HBuilderX / uni-app Vue3 环境下建议同时保留一份 Vite 风格变量，避免真机运行时未注入自定义 process.env
VITE_API_BASE_URL=https://api.example.com/api
VITE_MINI_PROGRAM_LOGIN_PATH=/auth/mini-program/login
VITE_WECHAT_APP_LOGIN_PATH=/auth/wechat/app/login
VITE_BIND_WECHAT_APP_PATH=/auth/bind/wechat/app
VITE_GOOGLE_APP_LOGIN_PATH=/auth/google/app/login
VITE_BIND_GOOGLE_APP_PATH=/auth/bind/google/app
